PORT=8080
OPENAI_API_KEY=

# LLM (Responses API)
OPENAI_MODEL=gpt-4.1-mini

# Built-in ASR/TTS via OpenAI (used when relay URLs below are empty)
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova

# Optional relays — leave empty to use OpenAI Whisper + OpenAI Speech on the server
WHISPER_UPSTREAM_WS=
TTS_UPSTREAM_URL=

REQUEST_TIMEOUT_MS=10000
